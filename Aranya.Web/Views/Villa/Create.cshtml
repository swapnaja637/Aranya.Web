@model Aranya.Domain.Entities.Villa

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card">
                <div class="card-header bg-success text-center text-white">
                    <h1>Create New Villa</h1>
                </div>
                <div class="card-body">
                    <div class="col-12 text-end p-1 mb-2">
                      <a asp-action="Index" asp-controller="Villa" class="btn btn-dark">Back to Villa <i class="bi bi-x-circle"></i></a>
                    </div>
                      <form method="post">
                        <div class="row mb-3">
                            <div class="col-3">
                                    <label asp-for="Name" class="form-label text-black"></label>
                            </div>
                        <div class="col-lg-9">
                            <input asp-for="Name" class="form-control" />
                        </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-3">
                                <label asp-for="Description" class="form-label text-black"></label>
                            </div>
                            <div class="col-9">
                            <textarea  class="form-control" asp-for="Description " ></textarea>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-3">
                                <label asp-for="Rate" class="form-label text-black"></label>
                            </div>
                            <div class="col-9">
                                <input asp-for="Rate" class="form-control" />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-3">
                                <label asp-for="Occupancy" class="form-label text-black"></label>
                            </div>
                            <div class="col-9">
                                <input asp-for="Occupancy" class="form-control" />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-3">
                                <label asp-for="Area" class="form-label text-black"></label>
                            </div>
                            <div class="col-9">
                                <input asp-for="Area" class="form-control" />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-3">
                                <label asp-for="ImageUrl" class="form-label text-black"></label>
                            </div>
                            <div class="col-9">
                                <input asp-for="ImageUrl" class="form-control" />
                            </div>
                        </div>
                        <div class="col-12 text-center border p-3">
                            <button type="submit" class="btn btn-primary">Save <i class="bi bi-plus-circle"></i></button>
                            <button type="reset" class="btn btn-danger">Clear <i class="bi bi-x-circle"></i></button>
                          
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>